{
  "uid": "hemera-fleet-overview",
  "title": "Constellation — Fleet Overview",
  "tags": ["hemera", "constellation", "fleet"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Scrape targets up",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "count(up == 1)", "datasource": { "type": "prometheus", "uid": "hemera-prometheus" } } ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Spans accepted by collector (rate)",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (receiver) (rate(otelcol_receiver_accepted_spans_total[5m]))", "legendFormat": "{{receiver}}", "datasource": { "type": "prometheus", "uid": "hemera-prometheus" } } ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Metric points exported (rate)",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (exporter) (rate(otelcol_exporter_sent_metric_points_total[5m]))", "legendFormat": "{{exporter}}", "datasource": { "type": "prometheus", "uid": "hemera-prometheus" } } ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Log records accepted (rate)",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(rate(otelcol_receiver_accepted_log_records_total[5m]))", "legendFormat": "log records/s", "datasource": { "type": "prometheus", "uid": "hemera-prometheus" } } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Collector export failures (rate)",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (exporter) (rate(otelcol_exporter_send_failed_metric_points_total[5m]) + rate(otelcol_exporter_send_failed_spans_total[5m]) + rate(otelcol_exporter_send_failed_log_records_total[5m]))", "legendFormat": "{{exporter}}", "datasource": { "type": "prometheus", "uid": "hemera-prometheus" } } ]
    }
  ]
}
