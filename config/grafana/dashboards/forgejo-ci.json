{
  "uid": "hemera-forgejo-ci",
  "title": "Forgejo CI — Runner Queue",
  "tags": ["forgejo", "ci", "actions"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Queue depth",
      "description": "Total Forgejo Actions jobs in the runner queue (waiting + running + blocked).",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "forgejo_actions_queue_total", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#fab219", "value": 3 },
              { "color": "#d03b3b", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Waiting",
      "description": "Jobs queued but not yet picked up by a runner (the backlog).",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "forgejo_actions_queue_jobs{status=\"waiting\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#fab219", "value": 1 },
              { "color": "#d03b3b", "value": 8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Running",
      "description": "Jobs currently executing on a runner.",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "forgejo_actions_queue_jobs{status=\"running\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "#199e70", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Runners active",
      "description": "Registered runners in the active state (queue capacity).",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "forgejo_actions_runners{status=\"active\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#d03b3b", "value": null },
              { "color": "#0ca30c", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Queue depth by status",
      "description": "In-flight jobs over time, stacked by status. The headline queue-over-time view.",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "forgejo_actions_queue_jobs",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "running" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#199e70" } }]
          },
          {
            "matcher": { "id": "byName", "options": "waiting" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#c98500" } }]
          },
          {
            "matcher": { "id": "byName", "options": "blocked" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#d03b3b" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["max", "lastNotNull"] }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Queue vs runner capacity",
      "description": "Total queued jobs against registered runners — backlog forms when queued outruns runners.",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 15 },
      "targets": [
        { "refId": "A", "expr": "forgejo_actions_queue_total", "legendFormat": "queued" },
        { "refId": "B", "expr": "forgejo_actions_runners_total", "legendFormat": "runners" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "queued" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }]
          },
          {
            "matcher": { "id": "byName", "options": "runners" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#8f8f8f" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 6] } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Exporter",
      "description": "1 if the last poll of the Forgejo admin Actions API succeeded. If down, the queue values are stale.",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "targets": [
        { "refId": "A", "expr": "forgejo_actions_up", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "#d03b3b" }, "1": { "text": "UP", "color": "#0ca30c" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#d03b3b", "value": null },
              { "color": "#0ca30c", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    }
  ]
}
