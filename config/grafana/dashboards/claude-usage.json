{
  "uid": "hemera-claude-usage",
  "title": "Claude Code — Usage",
  "tags": ["claude", "usage", "telemetry"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "7-day window — current",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(claude_usage_rate_limit_percent{window=\"seven_day\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#fab219", "value": 70 },
              { "color": "#d03b3b", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5-hour window — current",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(claude_usage_rate_limit_percent{window=\"five_hour\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#fab219", "value": 70 },
              { "color": "#d03b3b", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Rate-limit usage",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 12, "w": 16, "x": 8, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (window) (claude_usage_rate_limit_percent)",
          "legendFormat": "{{window}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": 3600000
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "seven_day" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }]
          },
          {
            "matcher": { "id": "byName", "options": "five_hour" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#199e70" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Context window used",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (hostname) (claude_usage_context_percent)",
          "legendFormat": "{{hostname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": 3600000
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rob02" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }]
          },
          {
            "matcher": { "id": "byName", "options": "hephaestus" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#199e70" } }]
          },
          {
            "matcher": { "id": "byName", "options": "nas01" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#c98500" } }]
          },
          {
            "matcher": { "id": "byName", "options": "llm01" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#008300" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Session cost",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (hostname) (claude_usage_session_cost_usd)",
          "legendFormat": "{{hostname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": 3600000
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rob02" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }]
          },
          {
            "matcher": { "id": "byName", "options": "hephaestus" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#199e70" } }]
          },
          {
            "matcher": { "id": "byName", "options": "nas01" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#c98500" } }]
          },
          {
            "matcher": { "id": "byName", "options": "llm01" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#008300" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    }
  ]
}
