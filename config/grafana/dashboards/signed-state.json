{
  "uid": "signed-state",
  "title": "Signed State — the die plane & the PDP",
  "tags": ["signed-state", "die-plane", "ouranos"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Die refusals (REFUSED cycles, 10m rate)",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(promtail_custom_refresher_refused_total[10m])",
          "legendFormat": "REFUSED (10m)"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": {} },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PDP request rate (by handler)",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"ouranos-opa\"}[5m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": {} },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "PDP consult latency (p95)",
      "datasource": { "type": "prometheus", "uid": "hemera-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ouranos-opa\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Refresher cycles (laid / noop / REFUSED) — digest + source_sha",
      "datasource": { "type": "loki", "uid": "hemera-loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "{container=~\"ouranos-refresher.*\"} |~ \"laid|noop|REFUSED|refresher up\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "PDP container log (errors & reloads)",
      "datasource": { "type": "loki", "uid": "hemera-loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "{container=\"ouranos-opa\"} |~ \"error|Error|reload|Reloading\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ]
}
